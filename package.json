{
  "name": "@monyone/aho-corasick",
  "version": "1.1.11",
  "author": "monyone <monyone.teihen@gmail.com>",
  "description": "Aho Corasick implementation written in TypeScript",
  "keywords": [
    "aho-corasick"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/monyone/aho-corasick"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./fast": {
      "import": {
        "types": "./dist/fast.d.mts",
        "default": "./dist/fast.mjs"
      },
      "require": {
        "types": "./dist/fast.d.cts",
        "default": "./dist/fast.cjs"
      }
    },
    "./greedy": {
      "import": {
        "types": "./dist/greedy.d.mts",
        "default": "./dist/greedy.mjs"
      },
      "require": {
        "types": "./dist/greedy.d.cts",
        "default": "./dist/greedy.cjs"
      }
    },
    "./stream": {
      "import": {
        "types": "./dist/stream/stream.d.mts",
        "default": "./dist/stream/stream.mjs"
      },
      "require": {
        "types": "./dist/stream/stream.d.cts",
        "default": "./dist/stream/stream.cjs"
      }
    },
    "./stream/web": {
      "import": {
        "types": "./dist/stream/web/stream-web.d.mts",
        "default": "./dist/stream/web/stream-web.mjs"
      },
      "require": {
        "types": "./dist/stream/web/stream-web.d.cts",
        "default": "./dist/stream/web/stream-web.cjs"
      }
    },
    "./stream/node": {
      "import": {
        "types": "./dist/stream/node/stream-node.d.mts",
        "default": "./dist/stream/node/stream-node.mjs"
      },
      "require": {
        "types": "./dist/stream/node/stream-node.d.cts",
        "default": "./dist/stream/node/stream-node.cjs"
      }
    }
  },
  "license": "MIT",
  "files": [
    "dist/**/*",
    "d.ts/**/*",
    "src/**/*",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsdown",
    "tsc": "tsc",
    "test": "vitest",
    "perf": "node ./perf/index.mts",
    "prepublishOnly": "tsdown"
  },
  "devDependencies": {
    "@tanishiking/aho-corasick": "^0.0.1",
    "@types/ahocorasick": "^1.0.0",
    "@types/chance": "^1.1.6",
    "@types/node": "24",
    "ahocorasick": "^1.0.2",
    "chance": "^1.1.11",
    "hoshino": "^2.1.0",
    "modern-ahocorasick": "^1.0.1",
    "tsdown": "^0.21.5",
    "tynisearch": "^1.0.11",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "word-match-helper": "^2.1.0"
  }
}
